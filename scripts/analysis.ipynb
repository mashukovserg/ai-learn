 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Analysis of unique higher education institutions in Kursk Region
",
    "
",
    "This notebook analyzes the `postupi_online 2026.csv` dataset to find the number of unique institutions in "Курская область"."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd
",
    "import numpy as np
",
    "
",
    "# Load the dataset
",
    "file_path = '/Users/sergei_mashukov/postupi_online 2026.csv'
",
    "df = pd.read_csv(file_path, low_memory=False)
",
    "
",
    "print(f'Total rows in dataset: {len(df)}')
",
    "print(f'Total columns: {len(df.columns)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Identifying the region/town information
",
    "# Check unique towns starting with 'Курск' or in the Kursk region
",
    "mask = df.astype(str).apply(lambda row: row.str.contains('Курск', case=False).any(), axis=1)
",
    "kursk_related = df[mask]
",
    "
",
    "print(f"Rows related to 'Курск': {len(kursk_related)}")
",
    "print("Towns found:", kursk_related['town'].unique())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Filter for institutions in Kursk Region
",
    "# Since 'town' seems to be the primary location column:
",
    "kursk_towns = ['Курск', 'Железногорск', 'Курчатов', 'Льгов', 'Щигры', 'Рыльск', 'Обоянь']
",
    "kursk_df = df[df['town'].isin(kursk_towns)]
",
    "
",
    "unique_institutions = kursk_df['institution.name'].unique()
",
    "num_unique = len(unique_institutions)
",
    "
",
    "print(f'Number of unique higher education institutions in Kursk Region: {num_unique}')
",
    "print('
Institutions list:')
",
    "for inst in sorted(unique_institutions.tolist()):
",
    "    print(f'- {inst}')"
   ]
  }
 ],
